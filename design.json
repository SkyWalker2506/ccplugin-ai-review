{
  "cds_version": "1.0",
  "name": "ccplugin-ai-review",
  "type": "plugin",
  "input_patterns": [
    {
      "type": "slash_command",
      "commands": [
        "/review-ai"
      ]
    },
    {
      "type": "auto_trigger",
      "keywords": [
        "pr review",
        "code review",
        "ai review"
      ],
      "confirm": false,
      "cooldown": 0
    }
  ],
  "output_patterns": [
    {
      "type": "terminal_text",
      "max_lines": 20
    },
    {
      "type": "structured_output",
      "description": "GitHub PR comments via API"
    }
  ],
  "lifecycle": {
    "preflight": {
      "required_tools": [
        "gh"
      ],
      "required_secrets": [
        "GITHUB_TOKEN",
        "OPENROUTER_API_KEY"
      ],
      "required_mcp": [
        "github"
      ]
    }
  },
  "error_handling": {
    "retry_network": true,
    "max_retries": 3,
    "fallback": "local review without OpenRouter"
  }
}
